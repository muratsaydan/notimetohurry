# Bu dosya repoda kalır (içinde gerçek sırra benzer değer YOK).
# Kopyala: secrets/local.env oluştur (bu ad gitignore’da), aşağıyı doldur.
# İstersen başka dosya adı da kullanabilirsin; secrets/ altında example.env dışındaki her şey git’e gitmez.
# Cursor / ben bu projede secrets/local.env okuyabilirim.

# --- n8n Public API ---
N8N_BASE_URL=https://n8n.saydan.net
N8N_API_KEY=

# --- İsteğe bağlı: e-posta (n8n SMTP veya başka servis) ---
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=
